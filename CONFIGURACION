add address=10.0.8.253/32 local-address=10.0.8.254 name=peer1
/ip ipsec profile
set [ find default=yes ] dh-group=modp1024 enc-algorithm=des hash-algorithm=\
    md5 name=ike-profile
/ip ipsec proposal
add auth-algorithms=md5 enc-algorithms=des name=ipsec-proposal
/ip pool
add name=dhcp_pool1 ranges=192.168.40.2-192.168.40.254
/ip dhcp-server
add address-pool=dhcp_pool1 interface=Bridge_VLAN40 name=dhcp1
/interface bridge port
add bridge=Bridge_VLAN40 interface=ether2
add bridge=Bridge_VLAN40 interface=ether3
add bridge=Bridge_VLAN40 interface=ether4
/ip address
add address=192.168.40.1/24 interface=Bridge_VLAN40 network=192.168.40.0
add address=10.0.8.254/24 interface=ether1 network=10.0.8.0
/ip dhcp-server network
add address=192.168.40.0/24 dns-server=8.8.8.8 gateway=192.168.40.1
/ip firewall nat
add action=accept chain=srcnat dst-address=192.168.0.0/16 src-address=\
    192.168.40.0/24
add action=masquerade chain=srcnat out-interface=ether1
#Ingresar manualmente la contrasena no la detecta por comandos
/ip ipsec identity
add peer=peer1 auth-method=pre-shared-key password=PASSWDVPN
/ip ipsec policy
add dst-address=192.168.0.0/16 peer=peer1 proposal=ipsec-proposal \
    src-address=192.168.40.0/24 tunnel=yes
/ip route
add disabled=no distance=1 dst-address=0.0.0.0/0 gateway=10.0.8.1 \
    routing-table=main scope=30 target-scope=10
/system identity
set name=MIK_R1

