end
config system interface
    edit "LAN-SWITCH"
        set vdom "root"
        set ip 192.168.60.1 255.255.255.0
        set allowaccess ping
        set type switch
        set snmp-index 15
    next 
end    
config system dhcp server
    edit 1
        set default-gateway 192.168.60.1
        set netmask 255.255.255.0
        set interface "LAN-SWITCH"
