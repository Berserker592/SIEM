================================================================
CISCO-ISP
================================================================
enable
conf ter
hostname R_ISP

!Enrutamiento
router ospf 10
 router-id 1.1.1.1
 passive-interface GigabitEthernet0/0
 default-information originate
 exit
 
!Configuracion de interfaces, enrutamiento y nat
interface GigabitEthernet0/0
 ip address 10.0.8.253 255.255.255.0
 ip nat outside
 ip ospf 10 area 0       
 no shut
interface GigabitEthernet0/1
 ip address 172.16.255.1 255.255.255.252
 ip nat inside
 ip ospf 10 area 0
 no shut
 exit
ip route 0.0.0.0 0.0.0.0 10.0.8.1

!CONFIGURACION NAT
ip access-list extended NAT
deny ip 192.168.0.0 0.0.255.255 192.168.0.0 0.0.255.255
permit ip 192.168.0.0 0.0.255.255 any
exit
ip nat inside source list NAT interface GigabitEthernet0/0 overload

!VPN IPSEC
crypto isakmp policy 1
encryption des
hash md5
authentication pre-share 
group 2 !Grupo Diffie hellman
lifetime 86400
exit

crypto isakmp key PASSWDVPN address 10.0.8.251
crypto isakmp key PASSWDVPN address 10.0.8.252
crypto isakmp key PASSWDVPN address 10.0.8.254

!ACL OFICINA REMOTA 1
ip access-list extended VPN_IPSEC_1
no permit ip 192.168.10.0 0.0.0.255 192.168.40.0 0.0.0.255
no permit ip 192.168.20.0 0.0.0.255 192.168.40.0 0.0.0.255
no permit ip 192.168.30.0 0.0.0.255 192.168.40.0 0.0.0.255
no permit ip 192.168.99.0 0.0.0.255 192.168.40.0 0.0.0.255
permit ip 192.168.0.0 0.0.255.255 192.168.40.0 0.0.0.255
exit

!ACL OFICINA REMOTA 2
ip access-list extended VPN_IPSEC_2
permit ip 192.168.10.0 0.0.0.255 192.168.50.0 0.0.0.255
permit ip 192.168.20.0 0.0.0.255 192.168.50.0 0.0.0.255
permit ip 192.168.30.0 0.0.0.255 192.168.50.0 0.0.0.255
permit ip 192.168.99.0 0.0.0.255 192.168.50.0 0.0.0.255
exit

!ACL OFICINA REMOTA 3
ip access-list extended VPN_IPSEC_3
permit ip 192.168.10.0 0.0.0.255 192.168.60.0 0.0.0.255
permit ip 192.168.20.0 0.0.0.255 192.168.60.0 0.0.0.255
permit ip 192.168.30.0 0.0.0.255 192.168.60.0 0.0.0.255
permit ip 192.168.99.0 0.0.0.255 192.168.60.0 0.0.0.255
exit


!METODO DE CIFRADO
crypto ipsec transform-set VPNIPSEC esp-des esp-md5-hmac
exit

!OFICINA REMOTA 1
crypto map CMAP 5 ipsec-isakmp
set peer 10.0.8.254
set transform-set VPNIPSEC
match address VPN_IPSEC_1
exit

!OFICINA REMOTA 2
crypto map CMAP 10 ipsec-isakmp
set peer 10.0.8.252
set transform-set VPNIPSEC
match address VPN_IPSEC_2
exit

!OFICINA REMOTA 3
crypto map CMAP 15 ipsec-isakmp
set peer 10.0.8.251
set transform-set VPNIPSEC
match address VPN_IPSEC_3
exit

int g0/0
crypto map CMAP
exit

